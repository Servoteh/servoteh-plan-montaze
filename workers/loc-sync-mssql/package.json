{
  "name": "loc-sync-mssql",
  "version": "0.1.0",
  "description": "Node worker: prenosi loc_sync_outbound_events iz Supabase-a u MSSQL preko sp_ApplyLocationEvent.",
  "type": "module",
  "private": true,
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --test test/",
    "backfill:work-orders": "node scripts/backfill-bigtehn-work-orders.js",
    "backfill:work-orders:dry": "node scripts/backfill-bigtehn-work-orders.js --dry-run",
    "backfill:work-orders:full": "node scripts/backfill-bigtehn-work-orders.js --full",
    "backfill:production": "node scripts/backfill-production-cache.js --scope=open",
    "backfill:production:dry": "node scripts/backfill-production-cache.js --scope=open --dry-run",
    "backfill:production:full": "node scripts/backfill-production-cache.js --scope=all",
    "backfill:production:full:dry": "node scripts/backfill-production-cache.js --scope=all --dry-run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "dotenv": "^16.4.5",
    "mssql": "^11.0.1"
  }
}
