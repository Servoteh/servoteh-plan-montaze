# Servoteh ERP — primer .env fajla.
#
# Kopiraj ovaj fajl u `.env` i popuni vrednostima iz Supabase Dashboard:
#   Settings → API → Project URL i Project API keys → anon public.
# `.env` je u .gitignore, ne ulazi u commit.
#
# U Cloudflare Pages-u iste vrednosti idu kao Environment Variables na
# Settings → Environment variables.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
